# ─── Backend ───────────────────────────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=development

# Frontend (usado no CORS)
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=sua_chave_secreta_aqui_min_32_caracteres
JWT_EXPIRES_IN=7d

# SQLite (caminho do arquivo do banco)
DB_PATH=./src/db/financialzap.sqlite

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Meta / WhatsApp API ───────────────────────────────────────────────────────

# App da Meta (usado para chamadas à Graph API)
META_APP_ID=seu_app_id_aqui
META_APP_SECRET=seu_app_secret_aqui

# Versão da Graph API
META_API_VERSION=v20.0

# URL base da Graph API
META_API_BASE_URL=https://graph.facebook.com

# Webhook verify token (para receber notificações da Meta)
META_WEBHOOK_VERIFY_TOKEN=seu_token_de_verificacao_aqui

# ─── Criptografia de tokens de acesso ─────────────────────────────────────────

# Chave de criptografia AES-256-GCM para os tokens dos clientes (exatamente 32 caracteres)
ENCRYPTION_KEY=sua_chave_de_criptografia_aes_256_aqui

# ─── Frontend ──────────────────────────────────────────────────────────────────

# URL da API backend (deixe vazio em dev — o proxy do Vite resolve automaticamente)
# Em produção: https://api.seudominio.com/api
VITE_API_URL=
